# ===== Servidor =====
PORT=3000

# ===== Anthropic (cérebro do agente) =====
ANTHROPIC_API_KEY=coloque_sua_chave_aqui
# Confirme o nome exato do modelo na sua conta (ex.: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== Meta WhatsApp Cloud API (canal oficial - primeiro contato/HSM) =====
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=smq-verify-troque-isto
META_GRAPH_VERSION=v21.0

# ===== Z-API (canal secundario - janela conversacional) =====
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=
# Canal padrao para RESPOSTAS dentro da janela: "meta" ou "zapi"
REPLY_CHANNEL=meta

# ===== Operacao / anti-spam =====
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=20
TIMEZONE_OFFSET=-3
MAX_MESSAGES_PER_LEAD_PER_DAY=8
MIN_DELAY_MS=3000
MAX_DELAY_MS=12000

# ===== Handoff: como notificar o corretor =====
# "log" (so registra), "meta" ou "zapi" (manda WhatsApp para o corretor)
HANDOFF_NOTIFY_CHANNEL=zapi
# numero do plantao (so usado se nao houver corretor na roleta nem no CRM), com DDI
FALLBACK_CORRETOR_PHONE=

# ===== CRM proprio (seumetroquadrado.click) =====
# Faz a roleta e notifica o corretor. Se CRM_TOKEN vazio, usa a roleta LOCAL (corretores.csv).
CRM_BASE_URL=https://seumetroquadrado.click
# "normal" (roleta padrao) ou "foco" (fila sem limite diario)
CRM_QUEUE=normal
# Token da campanha (vai na URL). Ex.: token da "Campanha Rio Branco".
CRM_TOKEN=
